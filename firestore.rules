rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Campos sensibles que solo el Admin SDK puede modificar
    function noSensitiveFieldsModified() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return !changedKeys.hasAny([
        'isPremium', 'premiumExpiry', 'premiumWelcomeSeen',
        'isBlocked', 'blockedUntil', 'blockedReason',
        'premiumPaymentRef', 'isAdmin', 'adminLevel',
        'customClaims', 'role'
      ]);
    }

    match /transactions/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.userId ||
        (request.resource.data.isShared == true &&
         request.auth.uid == request.resource.data.sharedOwnerUid) ||
        (request.resource.data.isSentIncome == true &&
         request.auth.uid == request.resource.data.sentByUid)
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        (resource.data.isShared == true &&
         resource.data.sharedOwnerUid == request.auth.uid) ||
        (resource.data.isSentIncome == true &&
         resource.data.sentByUid == request.auth.uid)
      );
    }

    match /cards/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /budgets/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /categories/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Perfil público: cualquier auth puede leer (búsqueda por userName),
    // solo el propio usuario puede escribir campos no sensibles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId && noSensitiveFieldsModified();
    }

    // Friendships: leer/eliminar si eres fromId o toId
    // Crear solo si eres el remitente (fromId)
    // Actualizar solo si eres el destinatario (toId) — aceptar/rechazar
    match /friendships/{docId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.fromId ||
         request.auth.uid == resource.data.toId);
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.fromId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.toId;
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.fromId ||
         request.auth.uid == resource.data.toId);
    }

    // Notificaciones: leer/actualizar solo el destinatario
    // Crear: cualquier auth, pero el fromUserId debe ser el propio usuario y el tipo debe ser válido
    match /notifications/{docId} {
      allow read, update: if request.auth != null &&
        request.auth.uid == resource.data.toUserId;
      allow create: if request.auth != null
        && request.resource.data.type in [
          'friend_request', 'friend_accepted',
          'shared_transaction_added', 'shared_transaction_updated', 'shared_transaction_deleted',
          'income_claim_added',
          'sent_income', 'sent_income_deleted',
          'shared_delete_request'
        ]
        && request.resource.data.toUserId is string
        && request.resource.data.data.fromUserId == request.auth.uid;
    }

    match /sharedTransactions/{sharedId} {
      // Solo participantes pueden leer
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantUids;

      // Solo el owner puede crear
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid;

      // Cualquier participante puede actualizar o eliminar
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.participantUids;
    }

    match /goals/{goalId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // pendingExternalLinks: ownership por email del token, campos permitidos restringidos
    match /pendingExternalLinks/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['links', 'email', 'createdAt'])
        && request.resource.data.links is list;
      allow update: if request.auth != null
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    // Feature flags, appConfig, security, announcements: lectura pública (sin datos sensibles)
    // Escritura solo via Admin SDK desde spendia-admin
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // OTP de reset de PIN: solo accesible via Admin SDK (Cloud Functions), nunca desde cliente
    match /pin_resets/{docId} {
      allow read, write: if false;
    }

    // Pagos premium: solo accesible via Admin SDK desde spendia-admin
    match /premiumPayments/{docId} {
      allow read, write: if false;
    }

    // Audit log: solo accesible via Admin SDK desde spendia-admin
    match /auditLog/{docId} {
      allow read, write: if false;
    }

    // HONEYPOT: Colección trampa — cualquier acceso se registra via Functions trigger
    match /honeypot/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /_adminAccess/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Honeypot logs: solo accesible via Admin SDK
    match /honeypotLogs/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /expenseGroups/{groupId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy;

      match /expenses/{expenseId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/expenseGroups/$(groupId)).data.createdBy;
      }
    }

  }
}
